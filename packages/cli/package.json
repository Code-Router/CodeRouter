{
  "name": "coderouter-cli",
  "version": "0.1.4",
  "type": "module",
  "description": "A coding-agent router that picks the best model for each task, runs edits in git-worktree sandboxes, and works with your existing Claude Code / Codex CLI or any API key (OpenAI, Anthropic, OpenRouter, ...).",
  "license": "MIT",
  "author": "Efe Acar",
  "homepage": "https://github.com/Code-Router/CodeRouter#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Code-Router/CodeRouter.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/Code-Router/CodeRouter/issues"
  },
  "keywords": [
    "ai",
    "coding-agent",
    "llm",
    "router",
    "cli",
    "openai",
    "anthropic",
    "openrouter",
    "claude-code",
    "codex"
  ],
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "coderouter": "./dist/cli.js",
    "cr": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm --filter @coderouter/core build && tsup"
  },
  "dependencies": {
    "@vscode/ripgrep": "^1.18.0",
    "ink": "^5.0.1",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@clack/prompts": "^0.8.2",
    "@coderouter/core": "workspace:*",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/ws": "^8.18.1",
    "cli-spinners": "^3.2.0",
    "commander": "^12.1.0",
    "kleur": "^4.1.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
