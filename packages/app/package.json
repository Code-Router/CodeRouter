{
  "name": "@coderouter/app",
  "version": "0.1.0",
  "private": true,
  "description": "CodeRouter Studio — Electron desktop app (Loops, Projects, Chats, Usage)",
  "author": "Efe Acar",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:renderer": "vite",
    "build:main": "tsup --config tsup.electron.config.ts",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "start": "electron .",
    "typecheck": "tsc --noEmit",
    "build:cli": "pnpm --filter @coderouter/core build && pnpm --filter coderouter-cli build",
    "stage:daemon": "node scripts/stage-daemon.mjs",
    "package": "npm run build && npm run build:cli && npm run stage:daemon && electron-builder"
  },
  "dependencies": {
    "@coderouter/core": "workspace:*",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "^1.21.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^42.0.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
